{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "render-auto-deploy",
	"main": "src/index.js",
	"compatibility_date": "2025-08-13",
	"observability": {
		"enabled": true
	},
	"triggers": {
		"crons": ["0 */1 * * *"]
	}
	"kv_namespaces": [
		{
			"binding": "TAG_STORAGE",
			"id": "e3842c18aa9d475a8f5661713899bf0c"
		}
	]
}
